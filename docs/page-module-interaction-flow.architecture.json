  "cards": [
    {
      "dot": "cyan",
      "title": "学校页如何使用",
      "items": [
        "进入 /university 后先看战略达成、外部对标、核心指标和风险总览",
        "点击排名、重点任务、学科、风险、指标卡进入对应详情页",
        "通过年份、排名类型、对标高校、学院/学科范围筛选，下钻到学院、学科或任务证据"
      ]
    },
    {
      "dot": "emerald",
      "title": "学院页如何使用",
      "items": [
        "进入 /college 后中心看学院发展总览，左右查看重点任务、教学质量、科研创新、就业与预警",
        "点击重点任务、高潜学生、预警、课程、科研平台、就业模块进入详情或弹窗",
        "学院端按本学院、专业、年级、班级筛选；重点学生和预警事项需要人工复核后使用"
      ]
    },
    {
      "dot": "violet",
      "title": "学生页如何使用",
      "items": [
        "进入 /student 后查看个人信息、学业发展、成长雷达、竞赛实践和 AI 成长助手",
        "课程横向对比只展示匿名统计，不能展示其他学生姓名、学号或具体成绩",
        "AI 建议必须引用证据，仅作为成长参考，辅导员确认后进入支持闭环"
      ]
    },
    {
      "dot": "rose",
      "title": "通用交互规则",
      "items": [
        "所有页面显示数据统计截止时间和最后更新时间",
        "刷新、重试、自动轮播、手动切换、详情下钻、导出都是可预期交互",
        "导出必须经过脱敏、水印、审批和权限限制；访问、查询、导出、配置均记录审计日志"
      ]
    }
  ]
