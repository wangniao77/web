  "cards": [
    {
      "dot": "cyan",
      "title": "前端三层驾驶舱",
      "items": [
        "统一门户 /portal，根路径 / 按 VITE_DEFAULT_VIEW 重定向",
        "学院 /college/*：KPI、任务、高潜、教学、科研、预警、就业（已联调）",
        "学校 /university/*：战略总览 + 科研/学科/任务/就业/风险详情",
        "学生 /student：个人成长大屏（Mock 为主）"
      ]
    },
    {
      "dot": "emerald",
      "title": "后端 API 域",
      "items": [
        "GET /api/health — 健康检查",
        "POST /api/v1/auth/login · GET /me — JWT 认证",
        "GET /api/v1/college/* — 学院大屏聚合接口（主力联调面）",
        "GET /api/v1/university/* — 学校总览与详情",
        "GET /api/v1/student/{id}/dashboard — 学生大屏",
        "GET/POST /api/v1/admin/* — 超级管理员 CRUD"
      ]
    },
    {
      "dot": "violet",
      "title": "数据层",
      "items": [
        "PostgreSQL governance_cockpit，aerich 管理 schema 迁移",
        "学籍宽表 + 重点任务 + 校园事件等 ORM 模型",
        "生产：Nginx 静态托管 + 反代 FastAPI，systemd 守护"
      ]
    }
