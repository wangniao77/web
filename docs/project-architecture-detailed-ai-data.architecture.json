  "cards": [
    {
      "dot": "cyan",
      "title": "外部数据查询接入位置",
      "items": [
        "新增 Utils/External 作为统一外部数据工具层，由 Services 调用",
        "接入排名、论文、专利、招聘、舆情、校内教务/科研/就业等来源",
        "外部结果先清洗落入快照/缓存表，再供驾驶舱查询，避免页面直接打外部接口"
      ]
    },
    {
      "dot": "violet",
      "title": "大模型接入位置",
      "items": [
        "前端 AI 入口只调用后端 /api/v1/agent/*，不直连模型服务",
        "后端通过 Services -> Utils/Agent/WorkFlow 编排工具调用和上下文",
        "Utils/Agent/API 负责对接云端或本地模型，模型输出写入审计日志"
      ]
    },
    {
      "dot": "rose",
      "title": "安全与治理",
      "items": [
        "调用外部接口和大模型前需要 JWT 鉴权、字段脱敏、密钥管理和限流",
        "学生个人信息、成绩、预警原因进入模型前应做最小化上下文裁剪",
        "保留 prompt、响应、工具调用轨迹，便于追溯和复核"
      ]
    },
    {
      "dot": "amber",
      "title": "推荐落地顺序",
      "items": [
        "先统一 /api/v1 与现有 Router -> Service -> Utils 规则",
        "再补外部数据快照表和定时同步任务",
        "最后接入 Agent 工作流，让大模型只通过工具读取已授权数据"
      ]
    }
  ]
}
