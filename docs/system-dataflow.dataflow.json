  ],
  "nodes": [
    { "id": "excel", "type": "external", "label": "学籍 Excel", "sublabel": "Datas/*.xlsx", "stage": 0, "row": 0, "tag": "离线源" },
    { "id": "mockJson", "type": "database", "label": "Mock 数据集", "sublabel": "frontend/src/mock", "stage": 0, "row": 2, "tag": "演示源" },
    { "id": "postgres", "type": "database", "label": "PostgreSQL", "sublabel": "governance_cockpit", "stage": 0, "row": 4, "tag": "持久化" },

    { "id": "etl", "type": "backend", "label": "Excel ETL", "sublabel": "app/importers", "stage": 1, "row": 0, "tag": "批量导入" },
    { "id": "httpReq", "type": "frontend", "label": "HTTP 请求", "sublabel": "axios /api/v1/*", "stage": 1, "row": 2, "tag": "联调路径" },
    { "id": "createSvc", "type": "frontend", "label": "createService", "sublabel": "Mock / Fetch 分支", "stage": 1, "row": 4, "tag": "调度" },

    { "id": "tortoise", "type": "backend", "label": "Tortoise ORM", "sublabel": "模型查询", "stage": 2, "row": 1, "tag": "读库" },
