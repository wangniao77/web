    { "id": "apiResp", "type": "backend", "label": "ApiResponse", "sublabel": "{ code, data, message }", "stage": 3, "row": 1, "tag": "DTO" },
    { "id": "adapters", "type": "frontend", "label": "Adapters", "sublabel": "DTO → ViewModel", "stage": 3, "row": 3, "tag": "映射" },

    { "id": "viewModel", "type": "frontend", "label": "ViewModel", "sublabel": "面板/图表绑定数据", "stage": 4, "row": 2, "tag": "展示模型" },
    { "id": "cockpit", "type": "frontend", "label": "大屏 UI", "sublabel": "Vue + ECharts", "stage": 4, "row": 4, "tag": "渲染" }
  ],
  "flows": [
