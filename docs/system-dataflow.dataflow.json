      "toSide": "top",
      "labelDy": 22
    }
  ],
  "cards": [
    {
      "dot": "emerald",
      "title": "联调主路径（真实数据）",
      "items": [
        "Vue 页面调用 createService.fetch → axios GET /api/v1/college/*",
        "FastAPI Router → CollegeService 从 PostgreSQL 聚合学籍、课程、任务",
        "返回 ApiResponse DTO → unwrapApiData → Adapter 转 ViewModel → 大屏渲染"
      ]
    },
    {
      "dot": "cyan",
      "title": "演示路径（Mock）",
      "items": [
        "VITE_USE_MOCK=true 时跳过 HTTP，直接读取 frontend/src/mock",
        "mock 数据经同一套 Adapter 转换，保证 UI 与联调结构一致",
        "适用于展厅部署或后端接口尚未就绪的模块"
      ]
    },
    {
      "dot": "violet",
      "title": "离线入库路径",
      "items": [
        "Datas/*.xlsx 经 app/importers 解析为学籍宽表记录",
        "bulk upsert 写入 PostgreSQL，供 CollegeService 实时聚合",
        "aerich 管理 accounts、tasks、events 等 schema 迁移"
      ]
    }
  ]
}
